# =============================================================================
# Unified Notification Service Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SMS Configuration (Twilio)
# -----------------------------------------------------------------------------
# Your Twilio Account SID
SMS_ACCOUNT_SID=your_twilio_account_sid

# Your Twilio Auth Token
SMS_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio phone number (in E.164 format, e.g., +1234567890)
SMS_FROM_NUMBER=+1234567890

# SMS Provider (default: twilio)
SMS_PROVIDER=twilio

# -----------------------------------------------------------------------------
# WhatsApp Configuration (Twilio WhatsApp Business API)
# -----------------------------------------------------------------------------
# Your Twilio Account SID (can be same as SMS_ACCOUNT_SID)
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid

# Your Twilio Auth Token
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio WhatsApp sender number (in E.164 format)
WHATSAPP_FROM_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Telegram Configuration
# -----------------------------------------------------------------------------
# Your Telegram Bot Token (obtained from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token:xxxxx

# -----------------------------------------------------------------------------
# Email (SMTP) Configuration
# -----------------------------------------------------------------------------
# SMTP Server Host
SMTP_HOST=smtp.example.com

# SMTP Server Port (default: 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Username (usually your email address)
SMTP_USERNAME=notifications@example.com

# SMTP Password
SMTP_PASSWORD=your_smtp_password

# Use TLS (default: true)
SMTP_USE_TLS=true

# From Email Address (optional - defaults to SMTP_USERNAME)
SMTP_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Webhook Configuration
# -----------------------------------------------------------------------------
# Default Webhook URL (can be overridden in send_notification call)
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook

# Webhook Request Timeout in seconds (default: 30)
WEBHOOK_TIMEOUT=30

# -----------------------------------------------------------------------------
# Database Configuration (for In-App Notifications)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=factory

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
DEBUG=false
